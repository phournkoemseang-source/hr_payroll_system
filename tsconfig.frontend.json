{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./frontend/js",
    "rootDir": "./frontend/ts",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true
  },
  "include": ["frontend/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
